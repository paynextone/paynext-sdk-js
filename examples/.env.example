# ============================================================
# PayNext Integration – Environment Variables
# ============================================================
# Copy the relevant section to your project's .env file.
# Find your API credentials in: PayNext Admin → Apps → Your App
# Find your Webhook Secret in: PayNext Admin → Webhooks → Your Endpoint
# ============================================================


# ──────────────────────────────────────────────
# Node.js / Express  (.env in project root)
# ──────────────────────────────────────────────
PAYNEXT_API_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYNEXT_API_SECRET=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYNEXT_BASE_URL=https://paynext.one
PAYNEXT_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx


# ──────────────────────────────────────────────
# Next.js  (.env.local in project root)
# ──────────────────────────────────────────────
PAYNEXT_API_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYNEXT_API_SECRET=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYNEXT_BASE_URL=https://paynext.one
PAYNEXT_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Public (safe to expose to browser)
NEXT_PUBLIC_APP_URL=https://your-app.com


# ──────────────────────────────────────────────
# PHP / Laravel  (.env in project root)
# ──────────────────────────────────────────────
PAYNEXT_API_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYNEXT_API_SECRET=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYNEXT_BASE_URL=https://paynext.one
PAYNEXT_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx


# ──────────────────────────────────────────────
# Testing — use these during development
# ──────────────────────────────────────────────
PAYNEXT_API_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
PAYNEXT_API_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYNEXT_BASE_URL=https://paynext.one
PAYNEXT_WEBHOOK_SECRET=whsec_test_xxxxxxxxxxxxxxxxxxxx
